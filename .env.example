# Optional — base URL for Slate Share panel public links + QR codes.
# No trailing slash. The form slug is appended: {base}/{slug}
# Example: https://805sealcoating.com/quote
VITE_PUBLIC_FORM_BASE=

# Optional — remote file upload endpoint for file_upload questions.
# POST multipart: file + questionId. JSON response: { "url": "..." } or { "key": "..." }
# When unset, optimized files are stored in the browser (IndexedDB) for demo/admin use.
# When VITE_SUPABASE_* is set, uploads go to Supabase Storage instead.
# VITE_UPLOAD_URL=

# Production Slate admin (ADR-028) — when both are set, admin uses Supabase + auth.
# Create a project at https://supabase.com and run migrations from supabase/migrations/.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Supabase Edge Functions — never expose in the SPA):
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# PSW_NOTIFY_EMAIL=hello@palmstreetweb.com
# PUBLIC_FORM_BASE=https://slateforms.vercel.app
