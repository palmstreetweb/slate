# Optional — base URL for Slate Share panel public links + QR codes.
# No trailing slash. The form slug is appended: {base}/{slug}
# Example: https://805sealcoating.com/quote
VITE_PUBLIC_FORM_BASE=

# Optional — remote file upload endpoint for file_upload questions.
# POST multipart: file + questionId. JSON response: { "url": "..." } or { "key": "..." }
# When unset, optimized files are stored in the browser (IndexedDB) for demo/admin use.
# VITE_UPLOAD_URL=
