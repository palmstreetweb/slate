{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:examples",
  "outputDirectory": "examples/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/brand", "destination": "/brand/index.html" },
    { "source": "/brand/", "destination": "/brand/index.html" },
    { "source": "/((?!brand/).*)", "destination": "/index.html" }
  ]
}
